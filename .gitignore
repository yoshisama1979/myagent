.env
data/financial/*
!data/financial/README.md
data/ycom/financial/*
!data/ycom/financial/README.md
*.Identifier

# 機密情報（APIキー・サービスアカウント等）
data/secrets/
*-key.json
service-account-*.json

# ランタイム生成物
data/cache/
__pycache__/

# 拠点横断メールボックスのメッセージ実体（クライアント情報を含み得る・git非追跡）
data/mailbox/

# 月次アップロードデータ（売上・コスト等）
data/monthly/

# overseer / slack のランタイム状態・ログ・ロック・ハートビート（毎サイクル書き換わる・git非追跡）
data/overseer/
data/slack/
site/overseer/last-tick.txt

# Windows のファイル属性メタデータ（NTFS Zone.Identifier）
*Zone.Identifier

# 別プロジェクトの移植元ソース（_assistant/ への移植元として一時的に配置。myagent の git 履歴には含めない）
harness-factory-main/

# _assistant/ のローカル環境（venv・.env・Python キャッシュ）
_assistant/.venv/
_assistant/.env
_assistant/__pycache__/
_assistant/**/__pycache__/

# BigQuery 等の bin ツール用 venv（コミットしない）
bin/.venv/

# Node tooling (VPS-only: hp-shot 撮影ツール)
node_modules/
package-lock.json

# HP分析ループの生データ・スクリーンショット（VPS-local・コミットしない＝大容量/再生成可）
data/hp-loop/cycles/

# decks: 安全確認まで PDF/画像は追跡しない（deck-format.md 🚨節）
site/decks/ai-hisho/*.pdf
site/decks/ai-hisho/deck-images/
# decks: 質問事項レポートの PDF は /questions-deck で毎回再生成する生成物＝追跡しない
site/decks/analysis-questions/*.pdf
site/decks/analysis-questions/*/*.pdf

