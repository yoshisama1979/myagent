# このファイルを `.env` にコピーして実値を設定する（_assistant/.env は gitignore 済み）。
# プロジェクトルートの .env で同じキーを設定済みなら、_assistant/.env は不要
# （load_dotenv が _assistant/.env → ../.env の順で探す）。

# --- Claude API ---
# 業務パートナーが Claude を呼ぶときのキー
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- hana-tools 外部API（myagent 既存と統一） ---
# 接続先（ステージング or 本番）
HANA_TOOLS_BASE_URL=https://stg.hana-tools.com
# 発行された API トークン（リクエストの X-API-TOKEN ヘッダに載せる）
HANA_TOOLS_API_TOKEN=your-hana-tools-token
# hana-tools 上の自分の user_id（「自分のToDo」の絞り込みに使う）
HANA_MY_USER_ID=1

# --- Chainlit 認証 ---
# ログインユーザー名
ASSISTANT_USER=yoshi
# ログインパスワード（32 文字以上推奨）
ASSISTANT_PASSWORD=set-a-strong-password-here
# Chainlit のセッション cookie の署名キー（ランダム 32 文字以上）
# 生成例: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CHAINLIT_AUTH_SECRET=replace-with-random-32-or-more-chars
