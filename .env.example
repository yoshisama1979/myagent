# このファイルを `.env` にコピーして実値を設定する（.env は gitignore 済み）。
# myagent プロジェクト全体で使う環境変数の雛形。

# --- hana-tools API（既存のスクリプト・bin/hana-api.sh 用） ---
HANA_TOOLS_API_TOKEN=your-token-here
HANA_TOOLS_BASE_URL=https://stg.hana-tools.com
# bin/hana-api.sh の既定 user_id（自分のToDo絞り込みなど）
HANA_TOOLS_DEFAULT_USER_ID=34

# --- Slack Incoming Webhook（bin/slack.sh 用・定期通知の送信先） ---
# Slack管理画面 → Apps → "Incoming Webhooks" → チャンネル選択 → URL発行 して貼る
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
# 送信先チャンネル名（取り違え防止のため表示用。任意）
SLACK_DESTINATION_LABEL=社内通知-はなさか

# --- Slack 受信（双方向・bin/slack-listen.py 用 / Socket Mode） ---
# api.slack.com/apps で「Slackアプリ」を作成して取得する（Incoming Webhook とは別物）。
#  1) Socket Mode を ON → App-Level Token（scope: connections:write）= xapp-...
#  2) OAuth & Permissions の Bot scope: chat:write, channels:history, app_mentions:read
#     （プライベートチャンネルなら channels:history の代わりに groups:history）
#  3) Event Subscriptions（Socket Mode）で bot events に message.channels を追加
#     （プライベートなら message.groups も）
#  4) ワークスペースにインストール → Bot User OAuth Token = xoxb-...
#  5) 対象チャンネルに Bot を招待（/invite @ボット名）
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxx
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
# 受信を見張るチャンネルID（Slackでチャンネル名→「概要」最下部、または共有リンク末尾の C... ）
SLACK_CHANNEL_ID=C0XXXXXXXXX

# --- Search Console / BigQuery 一括エクスポート（bin/gsc-fetch.py 用） ---
# GSC「一括データエクスポート」の BigQuery を読むサービスアカウント JSON のパス。
# JSON 実体は data/secrets/（gitignore済）に置く。中身はコミット・表示しない。
GSC_SA_JSON=data/secrets/gsc-sa.json

# --- 拠点横断メールボックス（bin/mailbox.sh 用・各拠点のマシンに配置） ---
# VPS の API エンドポイント（Tailscale 経由）。末尾スラッシュは任意。
MAILBOX_URL=http://100.123.104.87/tools/mailbox/
# このマシンが名乗るエージェントのトークン（data/secrets/mailbox-tokens.json の鍵と一致）。
# 生成例: openssl rand -hex 24 ／ 詳細は rules/modes/mailbox.md
MAILBOX_TOKEN=replace-with-this-agents-token

# --- _assistant（経営サポート業務パートナー）用 ---
# Claude API キー（業務パートナーが Claude を呼ぶ）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# 「自分の user_id」は上の HANA_TOOLS_DEFAULT_USER_ID を流用する（追加キー不要）

# --- _assistant Web UI 認証（FastAPI + cookie session） ---
# ログインユーザー名
ASSISTANT_USER=yoshi
# ログインパスワード（32 文字以上推奨）
ASSISTANT_PASSWORD=set-a-strong-password-here
# セッション cookie の署名キー（ランダム 32 文字以上）
# 生成例: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ASSISTANT_SESSION_SECRET=replace-with-random-32-or-more-chars
